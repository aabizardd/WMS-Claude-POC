# ---- Backend production environment ----
# Copy to .env.production (or set as platform secrets). NEVER commit real values.

NODE_ENV=production
PORT=3000

# PostgreSQL (Neon cloud). Use the connection string from the Neon dashboard.
# For a single backend instance the DIRECT (non-pooled) endpoint works for both
# the app and migrations. sslmode=require is mandatory.
#   postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/wms?sslmode=require
# (If you later scale out, switch to the -pooler endpoint + add a DIRECT_URL for
#  migrations.) On Railway Postgres, use the provided DATABASE_URL as-is.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/wms?sslmode=require"

# Auth — MUST be a long random secret in production.
JWT_SECRET="change-me-to-a-64+char-random-string"
JWT_EXPIRES_IN="1d"

# CORS: the public frontend origin(s), comma-separated. Not needed when the
# frontend is served same-origin behind a reverse proxy that forwards /api.
FRONTEND_ORIGIN="https://app.your-domain.com"

# Oracle / ERP bridge integration
ERP_BASE_URL="https://api-bridge-sb.motorsights.com/api/v1/bridge"
ERP_CLIENT_ID="your-client-id"
ERP_CLIENT_SECRET="your-client-secret"
ERP_SYNC_PAGE_SIZE=200
ERP_SYNC_PAGE_DELAY_MS=1500

# Background Oracle sync scheduler. Enable on exactly ONE instance only.
ERP_SYNC_SCHEDULER_ENABLED=true
ERP_SYNC_INTERVAL_MS=60000

# PostgreSQL connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wms?schema=public"

# JWT
# REQUIRED: the app refuses to start if this is unset or left as "dev-secret".
# Use a long, unique random string (e.g. `openssl rand -base64 48`).
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="1d"

# Server
PORT=3000
# Allowed origin for the frontend (CORS)
FRONTEND_ORIGIN="http://localhost:5173"

# Oracle / ERP bridge integration
ERP_BASE_URL="https://api-bridge-sb.motorsights.com/api/v1/bridge"
ERP_CLIENT_ID="your-client-id"
ERP_CLIENT_SECRET="your-client-secret"
ERP_SYNC_PAGE_SIZE=200
# Delay between page requests (ms) to respect the ERP rate limit
ERP_SYNC_PAGE_DELAY_MS=1500

# Background Oracle sync scheduler (incremental / Last Modified based).
# Runs an incremental sync for all mirrored modules periodically.
ERP_SYNC_SCHEDULER_ENABLED=true
# Scheduler interval in milliseconds (default 60000 = 1 minute)
ERP_SYNC_INTERVAL_MS=60000

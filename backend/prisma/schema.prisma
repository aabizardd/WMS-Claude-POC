generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgTrgm(map: "pg_trgm")]
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique // e.g. "users:create"
  resource    String // e.g. "users"
  action      String // read | create | update | delete | sync
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

// Join table: which permissions a role has.
model RolePermission {
  roleId       Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id          Int        @id @default(autoincrement())
  name        String // display name, derived from firstName + lastName
  firstName   String?    @map("first_name")
  lastName    String?    @map("last_name")
  email       String     @unique
  username    String     @unique
  password    String
  isActive    Boolean    @default(true)
  roleId      Int
  role        Role       @relation(fields: [roleId], references: [id])
  warehouseId String?    @map("warehouse_id")
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  // Optional org assignment. Subsidiary must belong to the chosen department
  // (department.subsidiaryId is a comma-joined list of subsidiary oracle ids).
  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])
  subsidiaryId String?     @map("subsidiary_id")
  subsidiary   Subsidiary? @relation(fields: [subsidiaryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  discrepancies        Discrepancy[]
  pickAssignments      PutawayItem[]
  pickingAssignments   PickingItem[]
  packingAssignments   PackingItem[]
  deliveryAssignments  DeliveryItem[]
  complaints           Complaint[]
  inventoryAdjustments InventoryAdjustment[] @relation("AdjustmentCreator")
  approvedAdjustments  InventoryAdjustment[] @relation("AdjustmentApprover")

  @@index([warehouseId])
  @@index([roleId])
  @@map("users")
}

// ===================== Material Management =====================

model Uom {
  id      String @id @default(uuid())
  uomName String @map("uom_name")
  uomCode String @unique @map("uom_code")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // back-relations from Material (one UOM may be used by many materials in several slots)
  primaryForMaterials   Material[] @relation("PrimaryUom")
  secondaryForMaterials Material[] @relation("SecondaryUom")
  weightForMaterials    Material[] @relation("WeightUom")
  dimensionForMaterials Material[] @relation("DimensionUom")
  binDimensions         Bin[]      @relation("BinDimensionUom")

  @@map("uoms")
}

model MaterialCategory {
  id                   String  @id @default(uuid())
  materialCategoryName String  @map("material_category_name")
  materialCategoryCode String  @unique @map("material_category_code")
  description          String?

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  materials Material[]

  @@map("material_categories")
}

model MaterialType {
  id               String  @id @default(uuid())
  materialTypeName String  @map("material_type_name")
  materialTypeCode String  @unique @map("material_type_code")
  description      String?

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  materials Material[]

  @@map("material_types")
}

model Material {
  id                     String  @id @default(uuid())
  erpDocId               String? @unique @map("erp_doc_id") // Oracle/NetSuite internalId
  materialName           String  @map("material_name")
  materialCode           String  @unique @map("material_code")
  conversionRateQuantity Float   @default(0) @map("conversion_rate_quantity")
  currency               String?

  materialLength Float @default(0) @map("material_length")
  materialWidth  Float @default(0) @map("material_width")
  materialHeight Float @default(0) @map("material_height")
  materialWeight Float @default(0) @map("material_weight")
  materialQty    Float @default(0) @map("material_qty")

  photos String[] @default([])

  // Masters (optional: items imported from ERP may not have them yet)
  materialCategoryId String?           @map("material_category_id")
  materialCategory   MaterialCategory? @relation(fields: [materialCategoryId], references: [id])
  materialTypeId     String?           @map("material_type_id")
  materialType       MaterialType?     @relation(fields: [materialTypeId], references: [id])

  // UOM slots (optional, matching the API where some are empty {})
  primaryUomId   String? @map("primary_uom_id")
  primaryUom     Uom?    @relation("PrimaryUom", fields: [primaryUomId], references: [id])
  secondaryUomId String? @map("secondary_uom_id")
  secondaryUom   Uom?    @relation("SecondaryUom", fields: [secondaryUomId], references: [id])
  weightUomId    String? @map("weight_uom_id")
  weightUom      Uom?    @relation("WeightUom", fields: [weightUomId], references: [id])
  dimensionUomId String? @map("dimension_uom_id")
  dimensionUom   Uom?    @relation("DimensionUom", fields: [dimensionUomId], references: [id])

  isActive   Boolean  @default(true) @map("is_active")
  createdBy  String?  @map("created_by")
  modifiedBy String?  @map("modified_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("modified_at")

  inventories     InventoryManagement[]
  salesOrderItems SalesOrderItem[]
  pickingItems    PickingItem[]
  packingItems    PackingItem[]
  deliveryItems   DeliveryItem[]
  adjustmentItems InventoryAdjustmentItem[]

  @@index([materialCategoryId])
  @@index([materialTypeId])
  @@index([primaryUomId])
  @@index([materialName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([materialCode(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("materials")
}

// ===================== Warehouse Management =====================

// Synced from the Oracle "locations" endpoint. Read-only mirror in WMS.
model Warehouse {
  id                     String    @id @default(uuid())
  oracleId               String    @unique @map("oracle_id") // Oracle location id
  name                   String
  isInactive             Boolean   @default(false) @map("is_inactive")
  parentId               String?   @map("parent_id")
  parentName             String?   @map("parent_name")
  subsidiaryId           String?   @map("subsidiary_id")
  subsidiaryName         String?   @map("subsidiary_name")
  locationType           String?   @map("location_type")
  locationTypeName       String?   @map("location_type_name")
  timezone               String?
  makeInventoryAvailable Boolean   @default(false) @map("make_inventory_available")
  lastModified           DateTime? @map("last_modified")
  createdBy              String?   @map("created_by")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  bins                 Bin[]
  users                User[]
  mrns                 Mrn[]
  goodsReceives        GoodsReceive[]
  putaways             Putaway[]
  inventories          InventoryManagement[]
  discrepancies        Discrepancy[]
  salesOrders          SalesOrder[]
  pickings             Picking[]
  packings             Packing[]
  deliveries           Delivery[]
  complaints           Complaint[]
  inventoryAdjustments InventoryAdjustment[]
  purchaseOrders       PurchaseOrder[]
  transferOrders       TransferOrder[]       @relation("TransferOrderFrom")

  @@index([subsidiaryId])
  @@index([parentId])
  @@map("warehouses")
}

model AreaType {
  id           String   @id @default(uuid())
  areaTypeName String   @map("area_type_name")
  areaTypeCode String   @unique @map("area_type_code")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  bins Bin[]

  @@map("area_types")
}

model Aisle {
  id        String   @id @default(uuid())
  aisleName String   @map("aisle_name")
  aisleCode String   @unique @map("aisle_code")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bins Bin[]

  @@map("aisles")
}

model Shelf {
  id         String   @id @default(uuid())
  shelfLabel String   @map("shelf_label")
  shelfCode  String   @unique @map("shelf_code")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  bins Bin[]

  @@map("shelves")
}

model Bin {
  id          String @id @default(uuid())
  binLabel    String @map("bin_label")
  binCode     String @unique @map("bin_code")
  binLength   Float  @default(0) @map("bin_length")
  binWidth    Float  @default(0) @map("bin_width")
  binHeight   Float  @default(0) @map("bin_height")
  maxCapacity Float  @default(0) @map("max_capacity")

  warehouseId String    @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  aisleId     String    @map("aisle_id")
  aisle       Aisle     @relation(fields: [aisleId], references: [id])
  shelfId     String    @map("shelf_id")
  shelf       Shelf     @relation(fields: [shelfId], references: [id])
  areaTypeId  String    @map("area_type_id")
  areaType    AreaType  @relation(fields: [areaTypeId], references: [id])

  dimensionUomId String? @map("dimension_uom_id")
  dimensionUom   Uom?    @relation("BinDimensionUom", fields: [dimensionUomId], references: [id])

  isActive   Boolean   @default(true) @map("is_active")
  // Virtual bins are auto-created per warehouse to hold Oracle-synced available
  // quantity when no physical bin is known (adjustable later via Adjust Bins).
  isVirtual  Boolean   @default(false) @map("is_virtual")
  createdBy  String?   @map("created_by")
  modifiedBy String?   @map("modified_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  modifiedAt DateTime? @map("modified_at")

  mrnItems           MrnItem[] // bins chosen as receive destination
  putawayItems       PutawayItem[]
  inventoryBinStocks InventoryBinStock[]
  pickingItems       PickingItem[]
  packingItems       PackingItem[]
  deliveryItems      DeliveryItem[]
  adjustmentItems    InventoryAdjustmentItem[]

  @@index([warehouseId])
  @@index([aisleId])
  @@index([shelfId])
  @@index([areaTypeId])
  @@index([binLabel(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("bins")
}

// ===================== Vendor Management =====================

// Synced from the Oracle "vendors" endpoint. Read-only mirror in WMS.
model Vendor {
  id                String    @id @default(uuid())
  oracleId          String    @unique @map("oracle_id") // Oracle internalId
  entityId          String?   @map("entity_id")
  companyName       String?   @map("company_name")
  email             String?
  phone             String?
  terms             String?
  termsDisplay      String?   @map("terms_display")
  subsidiaryId      String?   @map("subsidiary_id")
  subsidiaryDisplay String?   @map("subsidiary_display")
  lastModified      DateTime? @map("last_modified")
  createdBy         String?   @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([subsidiaryId])
  @@index([companyName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([entityId(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("vendors")
}

// ===================== Customer Management =====================

// Synced from the Oracle "customers" endpoint. Read-only mirror in WMS.
model Customer {
  id           String    @id @default(uuid())
  oracleId     String    @unique @map("oracle_id") // Oracle internalId
  entityId     String?   @map("entity_id")
  companyName  String?   @map("company_name")
  email        String?
  phone        String?
  lastModified DateTime? @map("last_modified")
  createdBy    String?   @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([companyName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([entityId(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("customers")
}

// Synced from the Oracle "department" endpoint. Read-only mirror in WMS.
model Department {
  id             String    @id @default(uuid())
  oracleId       String    @unique @map("oracle_id") // Oracle internalId
  name           String?
  isInactive     Boolean   @default(false) @map("is_inactive")
  parentId       String?   @map("parent_id")
  parentName     String?   @map("parent_name")
  subsidiaryId   String?   @map("subsidiary_id") // comma-joined Oracle ids
  subsidiaryName String?   @map("subsidiary_name")
  lastModified   DateTime? @map("last_modified")
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  users User[]

  @@index([subsidiaryId])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("departments")
}

// Synced from the Oracle "class" endpoint. Read-only mirror in WMS.
model Class {
  id             String    @id @default(uuid())
  oracleId       String    @unique @map("oracle_id") // Oracle internalId
  name           String?
  isInactive     Boolean   @default(false) @map("is_inactive")
  parentId       String?   @map("parent_id")
  parentName     String?   @map("parent_name")
  subsidiaryId   String?   @map("subsidiary_id") // comma-joined Oracle ids
  subsidiaryName String?   @map("subsidiary_name")
  lastModified   DateTime? @map("last_modified")
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  adjustments InventoryAdjustment[]

  @@index([subsidiaryId])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("classes")
}

// Synced from the Oracle "subsidiary" endpoint. Read-only mirror in WMS.
model Subsidiary {
  id           String    @id @default(uuid())
  oracleId     String    @unique @map("oracle_id") // Oracle subsidiary_id
  name         String? // subsidiary_name (short, e.g. "IEL")
  fullName     String?   @map("full_name") // subsidiary_fullname
  isDelete     Boolean   @default(false) @map("is_delete")
  lastModified DateTime? @map("last_modified") // from Oracle updated_at
  createdBy    String?   @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  users User[]

  @@map("subsidiaries")
}

// ===================== Inbound: MRN & Goods Receive =====================

// MRN = Oracle "PIB" (inbound shipment) header. Synced (read-only) with WMS
// status "Closed"; entering WMS auto-creates a Goods Receive doc (status "Open").
model Mrn {
  id                   String    @id @default(uuid())
  oracleId             String    @unique @map("oracle_id") // PIB id
  shipmentNumber       String?   @map("shipment_number")
  externalDocNumber    String?   @map("external_doc_number")
  externalId           String?   @map("external_id")
  oracleStatus         String?   @map("oracle_status") // e.g. inTransit
  status               String    @default("Closed") // WMS status
  expectedShippingDate String?   @map("expected_shipping_date")
  actualShippingDate   String?   @map("actual_shipping_date")
  expectedDeliveryDate String?   @map("expected_delivery_date")
  actualDeliveryDate   String?   @map("actual_delivery_date")
  memo                 String?
  vesselNumber         String?   @map("vessel_number")
  billOfLading         String?   @map("bill_of_lading")
  port                 String?
  dateCreated          String?   @map("date_created")
  lastModified         DateTime? @map("last_modified")

  receivingLocationId   String?    @map("receiving_location_id")
  receivingLocationName String?    @map("receiving_location_name")
  warehouseId           String?    @map("warehouse_id")
  warehouse             Warehouse? @relation(fields: [warehouseId], references: [id])

  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items MrnItem[]

  @@index([warehouseId])
  @@index([status])
  @@map("mrns")
}

model MrnItem {
  id    String @id @default(uuid())
  mrnId String @map("mrn_id")
  mrn   Mrn    @relation(fields: [mrnId], references: [id], onDelete: Cascade)

  poId   Int?   @map("po_id")
  itemId Int?   @map("item_id")
  lineId Int?   @map("line_id")
  poRate Float? @map("po_rate")

  itemName        String? @map("item_name")
  poNumber        String? @map("po_number")
  vendorId        Int?    @map("vendor_id")
  vendorName      String? @map("vendor_name")
  itemDescription String? @map("item_description")

  qtyExpected        Float @default(0) @map("qty_expected")
  qtyReceived        Float @default(0) @map("qty_received") // value from Oracle
  qtyRemaining       Float @default(0) @map("qty_remaining") // WMS-managed: 0, then = qty_actual on GR
  qtyActual          Float @default(0) @map("qty_actual") // WMS-entered actual (Goods Receive)
  shipmentItemAmount Float @default(0) @map("shipment_item_amount")

  // Destination bin chosen during Goods Receive.
  binId String? @map("bin_id")
  bin   Bin?    @relation(fields: [binId], references: [id])

  receivingLocationId   String? @map("receiving_location_id")
  receivingLocationName String? @map("receiving_location_name")

  putawayItems PutawayItem[]

  // Set when the item's received qty has been taken into inventory (idempotency guard).
  inventoriedAt DateTime? @map("inventoried_at")

  @@unique([mrnId, lineId])
  @@index([mrnId])
  @@index([binId])
  @@map("mrn_items")
}

enum GoodsReceiveStatus {
  Open
  Syncing
  OnProgress
  SyncFailed
  Closed
}

// Every inbound door funnels into a Goods Receive. The source is generic:
// PIB (MRN), PO (local vendor), customer return, or transfer return.
enum GoodsReceiveSource {
  PIB
  PO
  CUSTOMER_RETURN
  TRANSFER_RETURN
}

model GoodsReceive {
  id              String             @id @default(uuid())
  // Generic source: sourceDocId is the WMS internal id of the source document
  // (mrn.id for PIB, purchaseOrder.id for PO, ...). sourceDocNumber is a
  // denormalized human-readable number (e.g. shipment/PO number) for lists.
  sourceType      GoodsReceiveSource @default(PIB) @map("source_type")
  sourceDocId     String             @map("source_doc_id")
  sourceDocNumber String?            @map("source_doc_number")

  grNumber    String             @unique @map("gr_number")
  status      GoodsReceiveStatus @default(Open)
  warehouseId String?            @map("warehouse_id")
  warehouse   Warehouse?         @relation(fields: [warehouseId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  discrepancies Discrepancy[]
  putaways      Putaway[]
  // Received lines (PO source): the exact items+qty submitted to Oracle
  // item-receipt. PIB GRs keep using MRN items and leave this empty.
  items         GoodsReceiveItem[]

  // NOT unique: a PO can be received partially several times (one GR per Oracle
  // item receipt). PIB still creates at most one GR per MRN, enforced in code
  // (mrn-sync findFirst check), not by a constraint.
  @@index([sourceType, sourceDocId])
  @@index([warehouseId])
  @@index([status])
  @@index([sourceDocId])
  @@map("goods_receives")
}

// One received line of a Goods Receive (PO source): mirrors what was sent to
// the Oracle item-receipt endpoint.
model GoodsReceiveItem {
  id             String       @id @default(uuid())
  goodsReceiveId String       @map("goods_receive_id")
  goodsReceive   GoodsReceive @relation(fields: [goodsReceiveId], references: [id], onDelete: Cascade)

  lineNumber  Int?    @map("line_number") // PO line number sent as "line"
  itemDisplay String? @map("item_display")
  materialId  String? @map("material_id")
  qty         Float   @default(0) // actual received qty sent to Oracle

  createdAt DateTime @default(now()) @map("created_at")

  @@index([goodsReceiveId])
  @@map("goods_receive_items")
}

// ===================== Purchase Order (Local Vendor inbound) =====================

// Synced from Oracle "purchase-orders/get-list". Source doc for Inbound from
// Local Vendor. Only PO with po_status "pendingReceipt" can be received (GR),
// and — unlike PIB/MRN — a Goods Receive is NOT auto-created.
model PurchaseOrder {
  id            String  @id @default(uuid())
  oracleId      String  @unique @map("oracle_id") // Oracle po_id
  poNumber      String? @map("po_number")
  poDate        String? @map("po_date")
  poStatus      String? @map("po_status") // e.g. pendingReceipt
  poStatusLabel String? @map("po_status_label")
  memo          String?

  vendorId       Int?    @map("vendor_id")
  vendorName     String? @map("vendor_name")
  currencyId     Int?    @map("currency_id")
  currencySymbol String? @map("currency_symbol")

  approvalStatus        Int?    @map("approval_status")
  approvalStatusDisplay String? @map("approval_status_display")

  subsidiaryId      String? @map("subsidiary_id")
  subsidiaryDisplay String? @map("subsidiary_display")
  classDisplay      String? @map("class_display")
  departmentDisplay String? @map("department_display")

  locationOracleId String?    @map("location_oracle_id") // Oracle location id
  locationName     String?    @map("location_name")
  warehouseId      String?    @map("warehouse_id")
  warehouse        Warehouse? @relation(fields: [warehouseId], references: [id])

  createdByNetsuite String?   @map("created_by_netsuite")
  dateCreated       String?   @map("date_created")
  lastModified      DateTime? @map("last_modified")

  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lines PurchaseOrderLine[]

  @@index([warehouseId])
  @@index([poStatus])
  @@index([subsidiaryId])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id              String        @id @default(uuid())
  purchaseOrderId String        @map("purchase_order_id")
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  lineId       String  @map("line_id") // Oracle line_id (internal id, NOT the 1..n line number)
  lineNumber   Int?    @map("line_number") // Oracle linesequencenumber — used as "line" in item-receipt
  itemOracleId String? @map("item_oracle_id") // Oracle item id (-> materials.erp_doc_id)
  itemDisplay  String? @map("item_display")
  itemType     String? @map("item_type")
  description  String?

  quantity         Float @default(0)
  committed        Float @default(0)
  backordered      Float @default(0)
  quantityReceived Float @default(0) @map("quantity_received") // value from Oracle
  quantityBilled   Float @default(0) @map("quantity_billed")

  locationOracleId  String? @map("location_oracle_id")
  locationName      String? @map("location_name")
  departmentDisplay String? @map("department_display")
  classDisplay      String? @map("class_display")

  inboundShipmentNumber String? @map("inbound_shipment_number")
  inboundShipmentLineId Int?    @map("inbound_shipment_line_id")

  // Resolved WMS material (item_oracle_id -> materials.erp_doc_id). Optional.
  materialId String? @map("material_id")

  // WMS-managed (Goods Receive, phase 2): actual received + destination bin.
  qtyActual     Float     @default(0) @map("qty_actual")
  qtyRemaining  Float     @default(0) @map("qty_remaining")
  binId         String?   @map("bin_id")
  inventoriedAt DateTime? @map("inventoried_at")

  @@unique([purchaseOrderId, lineId])
  @@index([purchaseOrderId])
  @@map("purchase_order_lines")
}

// ===================== Transfer Order (Outbound from Transfer Stock) =====================

// Synced from Oracle "transfer-orders/get". Source doc for Outbound from
// Transfer Stock (goods move from one warehouse to another). warehouseId is the
// FROM location (outbound source) used for scoping; toWarehouseId is resolved
// for the destination.
model TransferOrder {
  id       String  @id @default(uuid())
  oracleId String  @unique @map("oracle_id") // Oracle transfer order id
  tranId   String? @map("tran_id")
  tranDate String? @map("tran_date")

  statusCode String? @map("status_code")
  statusName String? @map("status_name")

  fromLocationOracleId String?    @map("from_location_oracle_id")
  fromLocationName     String?    @map("from_location_name")
  warehouseId          String?    @map("warehouse_id") // = FROM location's WMS warehouse (scope)
  warehouse            Warehouse? @relation("TransferOrderFrom", fields: [warehouseId], references: [id])

  toLocationOracleId String? @map("to_location_oracle_id")
  toLocationName     String? @map("to_location_name")
  toWarehouseId      String? @map("to_warehouse_id") // destination WMS warehouse (scalar)

  memo         String?
  lastModified DateTime? @map("last_modified")
  dateCreated  String?   @map("date_created")

  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items    TransferOrderItem[]
  pickings Picking[]

  @@index([warehouseId])
  @@index([statusName])
  @@map("transfer_orders")
}

model TransferOrderItem {
  id              String        @id @default(uuid())
  transferOrderId String        @map("transfer_order_id")
  transferOrder   TransferOrder @relation(fields: [transferOrderId], references: [id], onDelete: Cascade)

  lineNumber   Int     @map("line_number")
  itemOracleId String? @map("item_oracle_id") // Oracle item id (-> materials.erp_doc_id)
  itemName     String? @map("item_name")
  description  String?

  quantity    Float @default(0)
  committed   Float @default(0)
  backordered Float @default(0)
  shipped     Float @default(0)
  picked      Float @default(0)
  packed      Float @default(0)
  fulfilled   Float @default(0)
  received    Float @default(0)

  // WMS-managed remaining-to-pick = committed at sync, decremented on picking.
  remainingQty Float @default(0) @map("remaining_qty")

  fromLocationOracleId String? @map("from_location_oracle_id")
  fromLocationName     String? @map("from_location_name")

  // Resolved WMS material (item_id -> materials.erp_doc_id). Optional.
  materialId String? @map("material_id")

  pickingItems  PickingItem[]
  packingItems  PackingItem[]
  deliveryItems DeliveryItem[]

  @@unique([transferOrderId, lineNumber])
  @@index([transferOrderId])
  @@map("transfer_order_items")
}

// ===================== Inventory Management =====================

// One row per material code per warehouse; quantities = sum of its bin stocks.
model InventoryManagement {
  id           String     @id @default(uuid())
  materialCode String     @map("material_code")
  materialId   String?    @map("material_id")
  material     Material?  @relation(fields: [materialId], references: [id])
  warehouseId  String?    @map("warehouse_id")
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])

  // Oracle-mirrored quantities kept at header level (not tracked per bin).
  qtyCommitted Float @default(0) @map("qty_committed")
  qtyOnOrder   Float @default(0) @map("qty_on_order")
  qtyBackOrder Float @default(0) @map("qty_back_order")
  qtyInTransit Float @default(0) @map("qty_in_transit")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  binStocks InventoryBinStock[]

  @@unique([materialCode, warehouseId])
  @@index([warehouseId])
  @@index([materialId])
  @@map("inventory_management")
}

// Inventory quantities tracked per bin location (source of truth for detail/list).
model InventoryBinStock {
  id          String              @id @default(uuid())
  inventoryId String              @map("inventory_id")
  inventory   InventoryManagement @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  binId String? @map("bin_id")
  bin   Bin?    @relation(fields: [binId], references: [id])

  reservedQty  Float @default(0) @map("reserved_qty")
  availQty     Float @default(0) @map("avail_qty")
  inTransitQty Float @default(0) @map("in_transit_qty")
  qualityIssue Float @default(0) @map("quality_issue")
  qtyIssue     Float @default(0) @map("qty_issue")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([inventoryId, binId])
  @@index([binId])
  @@map("inventory_bin_stocks")
}

// ===================== Inventory Adjustment =====================

enum InventoryAdjustmentType {
  qty_issue
  quality_issue
}

enum InventoryAdjustmentStatus {
  PendingApproval
  Approved
  Rejected
}

// Manual inventory adjustment. Created as Pending Approval (WH Manager); the
// inventory effect is applied later at approval (out of scope here). Groups
// multiple (material, bin) lines and optionally references discrepancy docs.
model InventoryAdjustment {
  id               String                    @id @default(uuid())
  adjustmentNumber String                    @unique @map("adjustment_number") // ADJ-YYYYMMDD-NNN
  warehouseId      String                    @map("warehouse_id")
  warehouse        Warehouse                 @relation(fields: [warehouseId], references: [id])
  adjustmentType   InventoryAdjustmentType   @map("adjustment_type")
  status           InventoryAdjustmentStatus @default(PendingApproval)
  note             String?

  // Header class chosen at create; its Class.oracleId is sent to Oracle.
  classId String? @map("class_id")
  class   Class?  @relation(fields: [classId], references: [id])

  // Oracle inventory_adjustment_id returned after a successful post. "-" until then.
  oracleId String @default("-") @map("oracle_id")

  createdById Int?  @map("created_by")
  createdBy   User? @relation("AdjustmentCreator", fields: [createdById], references: [id])

  // Approval (WH Manager). Set once when status leaves PendingApproval.
  approvedById         Int?      @map("approved_by")
  approvedBy           User?     @relation("AdjustmentApprover", fields: [approvedById], references: [id])
  approvedAt           DateTime? @map("approved_at")
  approvalReason       String?   @map("approval_reason")
  // Oracle-side approval status; "-" until WMS-approved, then "Pending Approval Oracle".
  oracleApprovalStatus String    @default("-") @map("oracle_approval_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items         InventoryAdjustmentItem[]
  discrepancies InventoryAdjustmentDiscrepancy[]

  @@index([warehouseId])
  @@index([status])
  @@index([classId])
  @@map("inventory_adjustments")
}

model InventoryAdjustmentItem {
  id           String              @id @default(uuid())
  adjustmentId String              @map("adjustment_id")
  adjustment   InventoryAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)

  materialId   String?   @map("material_id")
  material     Material? @relation(fields: [materialId], references: [id])
  materialCode String?   @map("material_code")
  materialName String?   @map("material_name")

  binId    String? @map("bin_id")
  bin      Bin?    @relation(fields: [binId], references: [id])
  binLabel String? @map("bin_label")

  // qty_issue type
  qtyAdjustment Float @default(0) @map("qty_adjustment")
  // quality_issue type
  qtyScrapped   Float @default(0) @map("qty_scrapped")
  qtyPassed     Float @default(0) @map("qty_passed")

  // Snapshot of the bin's quantities at create time (informational context).
  availAtCreate        Float @default(0) @map("avail_at_create")
  qtyIssueAtCreate     Float @default(0) @map("qty_issue_at_create")
  qualityIssueAtCreate Float @default(0) @map("quality_issue_at_create")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([adjustmentId])
  @@index([materialId])
  @@index([binId])
  @@map("inventory_adjustment_items")
}

// Discrepancy documents attached to an adjustment as a memo (many-to-many).
model InventoryAdjustmentDiscrepancy {
  adjustmentId  String              @map("adjustment_id")
  adjustment    InventoryAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  discrepancyId String              @map("discrepancy_id")
  discrepancy   Discrepancy         @relation(fields: [discrepancyId], references: [id], onDelete: Cascade)

  @@id([adjustmentId, discrepancyId])
  @@map("inventory_adjustment_discrepancies")
}

// ===================== Discrepancy =====================

enum DiscrepancyType {
  quantity
  quality
}

enum DiscrepancyFrom {
  inbound
  outbound
}

enum DiscrepancySource {
  GR
  Putaway
  Picking
  Packing
}

enum QtyDiscrepancyType {
  shortage
  overage
  quarantine
}

// One discrepancy header per (GR, type). Grouped by GR number + type.
model Discrepancy {
  id              String          @id @default(uuid())
  discrepancyId   String          @unique @map("discrepancy_id") // business code, e.g. DSC-<gr>-QTY
  grId            String?         @map("gr_id")
  goodsReceive    GoodsReceive?   @relation(fields: [grId], references: [id])
  pickingId       String?         @map("picking_id")
  picking         Picking?        @relation(fields: [pickingId], references: [id])
  reportedById    Int?            @map("reported_by")
  reportedBy      User?           @relation(fields: [reportedById], references: [id])
  discrepancyType DiscrepancyType @map("discrepancy_type")
  discrepancyFrom DiscrepancyFrom @map("discrepancy_from")
  warehouseId     String?         @map("warehouse_id")
  warehouse       Warehouse?      @relation(fields: [warehouseId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  details         DiscrepancyDetail[]
  adjustmentLinks InventoryAdjustmentDiscrepancy[]

  @@index([warehouseId])
  @@index([pickingId])
  @@index([grId])
  @@map("discrepancies")
}

model DiscrepancyDetail {
  id            String      @id @default(uuid())
  discrepancyId String      @map("discrepancy_id")
  discrepancy   Discrepancy @relation(fields: [discrepancyId], references: [id], onDelete: Cascade)

  poNumber   String            @map("po_number")
  itemName   String?           @map("item_name")
  mrnItemId  String?           @map("mrn_item_id")
  sourceFrom DiscrepancySource @map("source_from")

  qtyDiscrepancy     Int                @map("qty_discrepancy")
  qtyDiscrepancyType QtyDiscrepancyType @map("qty_discrepancy_type")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([discrepancyId])
  @@map("r_discrepancy_detail")
}

// ===================== Putaway =====================

enum PutawayStatus {
  Open
  OnProgress
  Closed
}

model Putaway {
  id           String        @id @default(uuid())
  putawayCode  String        @unique @map("putaway_code")
  grId         String?       @map("gr_id")
  goodsReceive GoodsReceive? @relation(fields: [grId], references: [id])
  warehouseId  String?       @map("warehouse_id")
  warehouse    Warehouse?    @relation(fields: [warehouseId], references: [id])
  status       PutawayStatus @default(Open)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items PutawayItem[]

  @@index([warehouseId])
  @@index([status])
  @@index([grId])
  @@map("putaways")
}

model PutawayItem {
  id        String  @id @default(uuid())
  putawayId String  @map("putaway_id")
  putaway   Putaway @relation(fields: [putawayId], references: [id], onDelete: Cascade)

  mrnItemId String  @map("mrn_item_id")
  mrnItem   MrnItem @relation(fields: [mrnItemId], references: [id])

  itemName     String? @map("item_name")
  poNumber     String? @map("po_number")
  materialCode String? @map("material_code")
  vendorName   String? @map("vendor_name")
  plannedQty   Float   @default(0) @map("planned_qty")

  pickerId Int?  @map("picker_id")
  picker   User? @relation(fields: [pickerId], references: [id])

  actualQty    Float   @default(0) @map("actual_qty")
  qualityIssue Float   @default(0) @map("quality_issue")
  qtyIssue     Float   @default(0) @map("qty_issue") // inbound qty shortfall
  remainingQty Float   @default(0) @map("remaining_qty")
  binId        String? @map("bin_id")
  bin          Bin?    @relation(fields: [binId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([putawayId])
  @@index([binId])
  @@map("putaway_items")
}

// ===================== Outbound: Sales Order =====================

// Synced from the Oracle "sales-orders" endpoint (status = Pending Fulfillment).
// Read-only mirror in WMS. Header/detail; upserted by oracle_id / (so, line).
model SalesOrder {
  id       String  @id @default(uuid())
  oracleId String  @unique @map("oracle_id") // Oracle sales order id
  tranId   String? @map("tran_id")
  tranDate String? @map("tran_date")

  statusCode String? @map("status_code")
  statusName String? @map("status_name")

  customerId   String? @map("customer_id")
  customerName String? @map("customer_name")

  memo String?

  // location -> WMS warehouse (by Oracle id) for scoping.
  locationOracleId String?    @map("location_oracle_id")
  locationName     String?    @map("location_name")
  warehouseId      String?    @map("warehouse_id")
  warehouse        Warehouse? @relation(fields: [warehouseId], references: [id])

  subsidiaryId   String? @map("subsidiary_id")
  subsidiaryName String? @map("subsidiary_name")
  currencyId     String? @map("currency_id")
  currencyName   String? @map("currency_name")

  totalAmount  Float     @default(0) @map("total_amount")
  lastModified DateTime? @map("last_modified")
  dateCreated  String?   @map("date_created")

  // WMS outbound fulfillment status (independent of Oracle status).
  deliveryStatus DeliveryStatus @default(Open) @map("delivery_status")

  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items    SalesOrderItem[]
  pickings Picking[]

  @@index([warehouseId])
  @@index([subsidiaryId])
  @@map("sales_orders")
}

model SalesOrderItem {
  id           String     @id @default(uuid())
  salesOrderId String     @map("sales_order_id")
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  lineNumber Int @map("line_number")

  // item_id -> materials.erp_doc_id
  itemOracleId String?   @map("item_oracle_id")
  itemName     String?   @map("item_name")
  materialId   String?   @map("material_id")
  material     Material? @relation(fields: [materialId], references: [id])

  quantity Float @default(0)
  rate     Float @default(0)
  amount   Float @default(0)
  shipped  Float @default(0)

  // WMS-managed: qty still to be picked. Initialised to quantity on sync,
  // decremented on Generate Picking. Preserved across incremental syncs.
  remainingQty Float @default(0) @map("remaining_qty")

  description String?
  locationId  String? @map("location_id")

  createdAt DateTime @default(now()) @map("created_at")

  pickingItems  PickingItem[]
  packingItems  PackingItem[]
  deliveryItems DeliveryItem[]

  @@unique([salesOrderId, lineNumber])
  @@index([materialId])
  @@map("sales_order_items")
}

// ===================== Outbound: Picking =====================

enum DeliveryStatus {
  Open
  ProgressPicking
}

enum PickingStatus {
  Open
  OnProgress
  Closed
}

// Outbound docs (Picking/Packing/Delivery) can originate from a Sales Order or
// a Transfer Order. sourceType discriminates; the matching FK is set.
enum OutboundSource {
  SALES_ORDER
  TRANSFER_ORDER
}

// A Picking Document generated from a Sales Order OR a Transfer Order.
model Picking {
  id          String @id @default(uuid())
  pickingCode String @unique @map("picking_code") // PICK-YYYYMMDD-NNN

  sourceType OutboundSource @default(SALES_ORDER) @map("source_type")

  salesOrderId String?     @map("sales_order_id")
  salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id])

  transferOrderId String?        @map("transfer_order_id")
  transferOrder   TransferOrder? @relation(fields: [transferOrderId], references: [id])

  warehouseId String?    @map("warehouse_id")
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  status PickingStatus @default(Open)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items         PickingItem[]
  discrepancies Discrepancy[]
  // Legacy 1:1 back-ref: set when this picking is the PRIMARY picking of a
  // packing (Packing.pickingId). Kept for delivery/discrepancy traversal.
  packing       Packing?

  // Membership: the packing this picking was packed into. Several pickings of
  // the same SO/TO can merge into one packing, so this — not `packing` — is
  // the field that decides whether a picking is still packable.
  packingId  String?  @map("packing_id")
  packingDoc Packing? @relation("PackingMembers", fields: [packingId], references: [id])

  @@index([salesOrderId])
  @@index([transferOrderId])
  @@index([warehouseId])
  @@index([status])
  @@index([packingId])
  @@map("pickings")
}

model PickingItem {
  id        String  @id @default(uuid())
  pickingId String  @map("picking_id")
  picking   Picking @relation(fields: [pickingId], references: [id], onDelete: Cascade)

  salesOrderItemId String?         @map("sales_order_item_id")
  salesOrderItem   SalesOrderItem? @relation(fields: [salesOrderItemId], references: [id])

  transferOrderItemId String?            @map("transfer_order_item_id")
  transferOrderItem   TransferOrderItem? @relation(fields: [transferOrderItemId], references: [id])

  materialId   String?   @map("material_id")
  material     Material? @relation(fields: [materialId], references: [id])
  materialCode String?   @map("material_code")
  materialName String?   @map("material_name")

  requestQty Float @default(0) @map("request_qty")

  // Picking progress (accumulated across inputs). remaining = request - actual - qtyIssue - qualityIssue.
  actualQty    Float @default(0) @map("actual_qty")
  qtyIssue     Float @default(0) @map("qty_issue")
  qualityIssue Float @default(0) @map("quality_issue")
  remainingQty Float @default(0) @map("remaining_qty")

  binId String? @map("bin_id")
  bin   Bin?    @relation(fields: [binId], references: [id])

  pickerId Int?  @map("picker_id")
  picker   User? @relation(fields: [pickerId], references: [id])

  status PickingStatus @default(Open)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([pickingId])
  @@index([materialId])
  @@index([binId])
  @@index([transferOrderItemId])
  @@map("picking_items")
}

// ===================== Outbound: Packing =====================

enum PackingStatus {
  Open
  Closed
}

// A Packing Document generated from one or more (Closed) Pickings that share
// the same source SO/TO. `pickingId` is the primary picking; `pickings` lists
// every merged member.
model Packing {
  id          String @id @default(uuid())
  packingCode String @unique @map("packing_code") // PACK-YYYYMMDD-NNN

  // Inherited from the source picking (SO or TO).
  sourceType OutboundSource @default(SALES_ORDER) @map("source_type")

  // Primary picking (first selected). All member pickings share the same SO/TO,
  // so source traversal through this one is representative.
  pickingId String  @unique @map("picking_id")
  picking   Picking @relation(fields: [pickingId], references: [id])

  // All pickings merged into this packing (includes the primary).
  pickings Picking[] @relation("PackingMembers")

  warehouseId String?    @map("warehouse_id")
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  status PackingStatus @default(Open)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items    PackingItem[]
  delivery Delivery?

  @@index([warehouseId])
  @@index([status])
  @@map("packings")
}

model PackingItem {
  id        String  @id @default(uuid())
  packingId String  @map("packing_id")
  packing   Packing @relation(fields: [packingId], references: [id], onDelete: Cascade)

  // Origin source line (SO or TO), carried from picking — for line mapping.
  salesOrderItemId String?         @map("sales_order_item_id")
  salesOrderItem   SalesOrderItem? @relation(fields: [salesOrderItemId], references: [id])

  transferOrderItemId String?            @map("transfer_order_item_id")
  transferOrderItem   TransferOrderItem? @relation(fields: [transferOrderItemId], references: [id])

  materialId   String?   @map("material_id")
  material     Material? @relation(fields: [materialId], references: [id])
  materialCode String?   @map("material_code")
  materialName String?   @map("material_name")

  qty Float @default(0) // base = picking actual qty (target to pack)

  // Packing progress (accumulated across inputs).
  // remaining = qty - actualQty - qtyIssue - qualityIssue.
  actualQty    Float @default(0) @map("actual_qty")
  qtyIssue     Float @default(0) @map("qty_issue")
  qualityIssue Float @default(0) @map("quality_issue")
  remainingQty Float @default(0) @map("remaining_qty")

  binId String? @map("bin_id")
  bin   Bin?    @relation(fields: [binId], references: [id])

  pickerId Int?  @map("picker_id")
  picker   User? @relation(fields: [pickerId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([packingId])
  @@index([materialId])
  @@index([binId])
  @@index([transferOrderItemId])
  @@map("packing_items")
}

// ===================== Outbound: Delivery =====================

enum DeliveryDocStatus {
  Open
  Closed
}

// A Delivery Document generated from a Packing. One delivery per packing.
// Carries the packing's header + detail. SDO ID is generated at Generate Shipment.
model Delivery {
  id           String  @id @default(uuid())
  deliveryCode String  @unique @map("delivery_code") // DEL-YYYYMMDD-NNN
  sdoId        String? @unique @map("sdo_id") // Oracle fulfillment document_no, set on shipment (falls back to SDO-YYYYMMDD-NNN if the response omits it)

  // Inherited from the source packing (SO or TO).
  sourceType OutboundSource @default(SALES_ORDER) @map("source_type")

  // Oracle Item Fulfillment result (set on successful Generate Shipment).
  oracleFulfillmentId Int? @map("oracle_fulfillment_id")
  oracleLocalId       Int? @map("oracle_local_id")

  packingId String  @unique @map("packing_id")
  packing   Packing @relation(fields: [packingId], references: [id])

  warehouseId String?    @map("warehouse_id")
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  status DeliveryDocStatus @default(Open)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items DeliveryItem[]

  @@index([warehouseId])
  @@index([status])
  @@map("deliveries")
}

model DeliveryItem {
  id         String   @id @default(uuid())
  deliveryId String   @map("delivery_id")
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  // Origin source line (SO or TO), carried from packing — for line mapping.
  salesOrderItemId String?         @map("sales_order_item_id")
  salesOrderItem   SalesOrderItem? @relation(fields: [salesOrderItemId], references: [id])

  transferOrderItemId String?            @map("transfer_order_item_id")
  transferOrderItem   TransferOrderItem? @relation(fields: [transferOrderItemId], references: [id])

  materialId   String?   @map("material_id")
  material     Material? @relation(fields: [materialId], references: [id])
  materialCode String?   @map("material_code")
  materialName String?   @map("material_name")

  qty Float @default(0)

  binId String? @map("bin_id")
  bin   Bin?    @relation(fields: [binId], references: [id])

  pickerId Int?  @map("picker_id")
  picker   User? @relation(fields: [pickerId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([deliveryId])
  @@index([materialId])
  @@index([binId])
  @@index([transferOrderItemId])
  @@map("delivery_items")
}

// ===================== Complaint =====================

enum ComplaintStatus {
  Open
  Solved
}

model Complaint {
  id              String          @id @default(uuid())
  complaintNumber String          @unique @map("complaint_number") // CMP-YYYYMMDD-NNN
  menuFeature     String          @map("menu_feature")
  title           String
  email           String
  description     String
  evidences       String[]        @default([]) // base64 data URLs, max 2
  status          ComplaintStatus @default(Open)

  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id])

  warehouseId String?    @map("warehouse_id")
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([warehouseId])
  @@index([status])
  @@map("complaints")
}

// ===================== Sync Log =====================

enum SyncStatus {
  success
  partial
  failed
}

// Records background/retry Oracle sync runs that had problems (failed/partial),
// so admins can review and retry them. Successful scheduler runs are not logged.
model SyncLog {
  id           String     @id @default(uuid())
  module       String // materials | warehouses | vendors | customers | mrn | sales-orders
  trigger      String // scheduler | retry
  status       SyncStatus
  lastModified String?    @map("last_modified") // the "since" value used
  upserted     Int?
  failed       Int?
  totalRecords Int?       @map("total_records")
  message      String?
  durationMs   Int?       @map("duration_ms")
  retriedAt    DateTime?  @map("retried_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@map("sync_logs")
}

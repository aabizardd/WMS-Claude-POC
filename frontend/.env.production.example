# ---- Frontend production environment (build-time) ----
# VITE_* variables are baked into the static build, so they are PUBLIC.
#
# Split-origin (e.g. Vercel/Netlify FE + separate backend host): set the
# backend's public API base URL (must include the /api prefix):
VITE_API_URL="https://api.your-domain.com/api"
#
# Same-origin (frontend + backend behind one reverse proxy / docker-compose):
# leave VITE_API_URL empty/unset — the app defaults to "/api".
